{
  "name": "tscord",
  "version": "1.0.0",
  "description": "Bun-first fork of TSCord — fully-featured Discord bot template (TypeScript + @rpbey/discordy + mikro-orm)",
  "license": "MIT",
  "private": true,
  "main": "build/main.js",
  "tscord": {
    "version": "2.4"
  },
  "scripts": {
    "build": "bun run build:clean && bun run build:compile && bun run install:plugins",
    "build:clean": "rm -rf build/",
    "build:compile": "tsc --project tsconfig.json --skipLibCheck && bun run build:alias",
    "build:alias": "tsc-alias -p tsconfig.json",
    "build:start": "bun run build && bun run start",
    "install:plugins": "installoop --rootDir=./build/plugins",
    "type:check": "tsc --pretty --skipLibCheck --noEmit",
    "start": "NODE_ENV=production bun build/main.js",
    "dev": "NODE_ENV=development bun --watch src/main.ts",
    "i18n": "typesafe-i18n",
    "migration:create": "NODE_ENV=development SKIP_SCHEDULE=1 bunx mikro-orm migration:create",
    "migration:up": "NODE_ENV=development SKIP_SCHEDULE=1 bunx mikro-orm migration:up",
    "migration:down": "NODE_ENV=development SKIP_SCHEDULE=1 bunx mikro-orm migration:down",
    "plugins:install": "installoop --rootDir=./src/plugins",
    "postinstall": "bun run plugins:install",
    "lint": "oxlint --config .oxlintrc.json --type-aware src",
    "lint:fix": "oxlint --config .oxlintrc.json --fix src",
    "lint:fast": "oxlint --config .oxlintrc.json src",
    "lint:eslint": "eslint ."
  },
  "dependencies": {
    "@rpbey/importer": "workspace:*",
    "@rpbey/pagination": "workspace:*",
    "@rpbey/utilities": "workspace:*",
    "@rpbey/discordx": "workspace:*",
    "@mikro-orm/cli": "^6.6.13",
    "@mikro-orm/core": "^6.6.13",
    "@mikro-orm/entity-generator": "^6.6.13",
    "@mikro-orm/migrations": "^6.6.13",
    "@mikro-orm/sql-highlighter": "~1.0.1",
    "@mikro-orm/sqlite": "^6.6.13",
    "@tsed/common": "^7.87.9",
    "@tsed/core": "^7.87.9",
    "@tsed/di": "^7.87.9",
    "@tsed/exceptions": "^7.87.9",
    "@tsed/json-mapper": "^7.87.9",
    "@tsed/platform-express": "^7.87.9",
    "@tsed/schema": "^7.87.9",
    "@tsed/swagger": "^7.87.9",
    "archiver": "^7.0.1",
    "axios": "^1.15.2",
    "body-parser": "^1.20.5",
    "boxen": "~5.1.2",
    "case": "~1.6.3",
    "chalk": "~4.1.2",
    "chokidar": "~3.6.0",
    "cron": "~3.2.1",
    "cron-validator": "~1.3.1",
    "dayjs": "^1.11.20",
    "discord-api-types": "~0.37.120",
    "discord-logs": "~2.2.1",
    "discord-oauth2": "~2.12.1",
    "discord.js": "^14.26.3",
    "envalid": "^8.1.1",
    "express": "^4.22.1",
    "fast-folder-size": "~2.3.0",
    "http-status-codes": "~2.3.0",
    "image-hash": "^7.0.1",
    "imgur": "^2.5.0",
    "installoop": "^1.1.0",
    "joi": "~17.13.3",
    "node-os-utils": "~1.3.7",
    "ora": "~5.4.1",
    "pidusage": "~3.0.2",
    "reflect-metadata": "~0.2.2",
    "rentry-pastebin": "~1.3.0",
    "rxeta": "~1.1.2",
    "saveqlite": "~1.1.2",
    "semver": "^7.7.4",
    "stacktrace-parser": "~0.1.11",
    "swagger-ui-express": "~5.0.1",
    "ts-toolbelt": "^9.6.0",
    "tsyringe": "^4.10.0",
    "typesafe-i18n": "^5.27.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^2.27.3",
    "@types/archiver": "^6.0.4",
    "@types/body-parser": "^1.19.6",
    "@types/dateformat": "~5.0.3",
    "@types/express": "~4.17.25",
    "@types/node": "~20.17.58",
    "@types/node-os-utils": "~1.3.4",
    "@types/pidusage": "~2.0.5",
    "@types/semver": "^7.7.1",
    "@types/swagger-ui-express": "~4.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "ncp": "~2.0.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.22.0",
    "plop": "^2.7.6",
    "tsc-alias": "~1.8.16",
    "tsconfig-paths": "~4.2.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3"
  },
  "mikro-orm": {
    "useTsNode": false,
    "configPaths": [
      "./mikro-orm.config.ts",
      "./build/mikro-orm.config.js"
    ]
  }
}
